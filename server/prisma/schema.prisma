generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  DISCONTINUED
}

enum OrderStatus {
  PENDING_APPROVAL
  APPROVED
  PAYMENT_PENDING
  PAID
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

model User {
  id           String    @id @default(uuid())
  publicId     String    @unique @map("public_id")
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(CUSTOMER)
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  /// E.164-style normalized unique phone (required for new customer registrations)
  phone              String?   @unique @map("phone")
  phoneVerifiedAt    DateTime? @map("phone_verified_at")
  permanentAddress   Json?     @map("permanent_address")
  presentAddress     Json?     @map("present_address")
  deliveryAddress    Json?     @map("delivery_address")
  googleId           String?   @unique @map("google_id")
  facebookId         String?   @unique @map("facebook_id")
  consentAt          DateTime? @map("consent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  cartItems            CartItem[]
  orders               Order[]
  complaints           Complaint[]
  favorites            Favorite[]
  productReviews       ProductReview[]

  @@map("users")
}

model PhoneOtp {
  id        String   @id @default(uuid())
  phoneNorm String   @map("phone_norm")
  codeHash  String   @map("code_hash")
  purpose   String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phoneNorm, purpose])
  @@map("phone_otps")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Category {
  id               String     @id @default(uuid())
  publicId         String     @unique @map("public_id")
  slug             String     @unique
  name             String
  nameBn           String?    @map("name_bn")
  parentId         String?    @map("parent_id")
  parent           Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children         Category[] @relation("CategoryTree")
  sortOrder        Int        @default(0) @map("sort_order")
  /// JSON array: { key, name, type, required, options? } for dynamic product attributes
  attributeSchema  Json?      @map("attribute_schema")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  products         Product[]

  @@map("categories")
}

model Product {
  id                 String         @id @default(uuid())
  publicId           String         @unique @map("public_id")
  sku                String         @unique
  name               String
  nameBn             String?        @map("name_bn")
  description        String         @db.Text
  shortDesc          String?        @map("short_desc")
  brand              String?        @db.VarChar(128)
  specs              Json?
  /// Category-defined attribute values: { [attributeKey]: string | number | boolean }
  attributes         Json?          @map("attributes")
  price              Decimal        @db.Decimal(12, 2)
  comparePrice       Decimal?       @map("compare_price") @db.Decimal(12, 2)
  stock              Int            @default(0)
  readyToShip        Boolean        @default(true) @map("ready_to_ship")
  status             ProductStatus  @default(ACTIVE)
  mainImageUrl       String?        @map("main_image_url") @db.Text
  mainImagePublicId  String?        @map("main_image_public_id") @db.VarChar(512)
  galleryUrls        Json?          @map("gallery_urls")
  categoryId         String         @map("category_id")
  category           Category       @relation(fields: [categoryId], references: [id])
  featured           Boolean        @default(false)
  badgeNew           Boolean        @default(false) @map("badge_new")
  badgeBestseller    Boolean        @default(false) @map("badge_bestseller")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  cartItems      CartItem[]
  orderItems     OrderItem[]
  favorites      Favorite[]
  productReviews ProductReview[]

  @@index([categoryId])
  @@index([featured])
  @@index([status])
  @@index([brand])
  @@map("products")
}

model ShopBrand {
  id           String   @id @default(uuid())
  brandKey     String   @unique @map("brand_key") @db.VarChar(191)
  displayName  String   @map("display_name") @db.VarChar(128)
  logoUrl      String?  @map("logo_url") @db.Text
  logoPublicId String?  @map("logo_public_id") @db.VarChar(512)
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("shop_brands")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, productId])
  @@map("cart_items")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}

model ProductReview {
  id        String   @id @default(uuid())
  publicId  String   @unique @map("public_id")
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([productId, userId])
  @@index([productId])
  @@map("product_reviews")
}

model Order {
  id                   String      @id @default(uuid())
  publicId             String      @unique @map("public_id")
  userId               String      @map("user_id")
  user                 User        @relation(fields: [userId], references: [id])
  status               OrderStatus @default(PENDING_APPROVAL)
  paymentMethod        String?     @map("payment_method")
  paymentReference     String?     @map("payment_reference")
  paymentStatus        String      @default("awaiting_approval") @map("payment_status")
  advancePercent       Int         @default(100) @map("advance_percent")
  advanceAmount        Decimal     @map("advance_amount") @db.Decimal(12, 2)
  subtotal             Decimal     @db.Decimal(12, 2)
  shippingTotal        Decimal     @default(0) @map("shipping_total") @db.Decimal(12, 2)
  total                Decimal     @db.Decimal(12, 2)
  currency             String      @default("BDT")
  shippingAddress      Json        @map("shipping_address")
  contactEmail         String      @map("contact_email")
  contactPhone         String?     @map("contact_phone")
  notes                String?     @db.Text
  shipmentTrackingId   String?     @map("shipment_tracking_id") @db.VarChar(255)
  courierName          String?     @map("courier_name") @db.VarChar(160)
  shipmentTrackingUrl  String?     @map("shipment_tracking_url") @db.Text
  invoicePublicId      String?     @unique @map("invoice_public_id") @db.VarChar(80)
  invoiceIssuedAt      DateTime?   @map("invoice_issued_at")
  receiptPublicId      String?     @unique @map("receipt_public_id") @db.VarChar(80)
  receiptIssuedAt      DateTime?   @map("receipt_issued_at")
  approvedAt           DateTime?   @map("approved_at")
  paymentPendingAt     DateTime?   @map("payment_pending_at")
  paidAt               DateTime?   @map("paid_at")
  shippedAt            DateTime?   @map("shipped_at")
  outForDeliveryAt     DateTime?   @map("out_for_delivery_at")
  deliveredAt          DateTime?   @map("delivered_at")
  completedAt          DateTime?   @map("completed_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String  @map("order_id")
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String  @map("product_id")
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Decimal @map("unit_price") @db.Decimal(12, 2)
  nameSnapshot String  @map("name_snapshot")

  @@map("order_items")
}

model Advertisement {
  id                    String    @id @default(uuid())
  publicId              String    @unique @map("public_id")
  title                 String
  imageUrl              String    @map("image_url") @db.Text
  imagePublicId         String?   @map("image_public_id") @db.VarChar(512)
  linkUrl               String?   @map("link_url")
  linkProductPublicId   String?   @map("link_product_public_id") @db.VarChar(64)
  linkCategoryPublicId  String?   @map("link_category_public_id") @db.VarChar(64)
  placement             String    @default("home_hero")
  sortOrder             Int       @default(0) @map("sort_order")
  isActive              Boolean   @default(true) @map("is_active")
  startsAt              DateTime? @map("starts_at")
  endsAt                DateTime? @map("ends_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("advertisements")
}

model Complaint {
  id              String   @id @default(uuid())
  publicId        String   @unique @map("public_id")
  userId          String?  @map("user_id")
  user            User?    @relation(fields: [userId], references: [id])
  email           String
  subject         String
  message         String   @db.Text
  status          String   @default("open")
  resolutionDueAt DateTime @map("resolution_due_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("complaints")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  userId     String?  @map("user_id")
  ip         String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}
