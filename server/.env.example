NODE_ENV=development
PORT=5000
# Must match docker-compose MYSQL_USER / MYSQL_PASSWORD (default shop/shop).
# Old Docker volumes ignore password changes in compose — run: bash scripts/sync-db-shop-user.sh
DATABASE_URL="mysql://shop:shop@localhost:3306/shop"
JWT_ACCESS_SECRET="replace_with_at_least_32_random_characters_aaaa"
JWT_REFRESH_SECRET="replace_with_at_least_32_random_characters_bbbb"
# Comma-separated browser origins (Vite dev, preview, etc.)
CLIENT_ORIGIN="http://localhost:5173,http://localhost:5174"
# Optional shared cookie domain for production (api.example.com + www.example.com)
# COOKIE_DOMAIN=.example.com
# Optional: Cloudinary for image CDN. If unset, uploads are stored on disk under server/uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: public API base for absolute image URLs (e.g. https://api.example.com). Uses request host if unset.
# PUBLIC_API_URL=http://127.0.0.1:5000
UPLOAD_MAX_BYTES=2097152
# Products at or below this stock (and >0) appear as low-stock in admin analytics
LOW_STOCK_THRESHOLD=5

# Google Sign-In (Web client ID) — same ID as VITE_GOOGLE_CLIENT_ID on the client
GOOGLE_CLIENT_ID=

# Facebook Login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# SMS OTP (Twilio). Without these, dev uses console log; production needs Twilio or SMS will error.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional separate secret for OTP HMAC (defaults to JWT_ACCESS_SECRET)
OTP_HMAC_SECRET=

# Local dev: return SMS code in API response (never enable in production)
OTP_RETURN_IN_RESPONSE=true
